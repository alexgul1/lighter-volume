# Lighter API Configuration
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai

# Dual Account Configuration (Hedging Strategy)
# Account 1 - Primary account for hedged pairs
LIGHTER_ACCOUNT_1_PRIVATE_KEY=your_account_1_api_key_private_key_here
LIGHTER_ACCOUNT_1_INDEX=1
LIGHTER_ACCOUNT_1_API_KEY_INDEX=2

# Account 2 - Secondary account for hedged pairs
LIGHTER_ACCOUNT_2_PRIVATE_KEY=your_account_2_api_key_private_key_here
LIGHTER_ACCOUNT_2_INDEX=1
LIGHTER_ACCOUNT_2_API_KEY_INDEX=2

# Legacy Single Account Support (if not using dual account mode)
# LIGHTER_API_KEY_PRIVATE_KEY=your_api_key_private_key_here
# LIGHTER_ACCOUNT_INDEX=1
# LIGHTER_API_KEY_INDEX=2

# Account Type (standard or premium)
ACCOUNT_TYPE=standard

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=lighter_bot
MONGODB_COLLECTION=transactions

# Trading Strategy Configuration
MIN_TRADE_AMOUNT_USDC=10.0
MAX_TRADE_AMOUNT_USDC=50.0
TRADING_TOKENS=ETH,BTC,SOL
DEFAULT_LEVERAGE=3

# Hedging Configuration
# Percentage variance between paired trades (to avoid exact matching)
TRADE_AMOUNT_VARIANCE_PERCENT=2.0

# Random delay between opening paired positions (in seconds)
TRADE_TIMING_DELAY_MIN=1.0
TRADE_TIMING_DELAY_MAX=5.0

# Position Timing Configuration (in seconds)
# Default: 1-3 hours = 3600-10800 seconds
POSITION_HOLD_TIME_MIN=3600
POSITION_HOLD_TIME_MAX=10800

# Delay between opening new position pairs (in seconds)
DELAY_BETWEEN_TRADES=10

# Low Open Interest (OI) Token Selection
# Enable filtering for low OI tokens (better farming rewards)
ENABLE_LOW_OI_FILTER=true

# Maximum open interest threshold in USDC
MAX_OPEN_INTEREST_THRESHOLD=1000000

# Minimum number of markets required when filtering by OI
MIN_MARKETS_FOR_OI_FILTER=2

# Error Handling Configuration
# Number of consecutive failures before pausing and restarting
MAX_CONSECUTIVE_FAILURES=7

# Pause duration before restart (in seconds)
PAUSE_DURATION_SECONDS=60

# Logging Configuration
LOG_LEVEL=INFO
