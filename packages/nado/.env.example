# Nado.xyz Fast Token Rotation Bot Configuration

# ====================
# REQUIRED
# ====================

# Your wallet private key (with 0x prefix)
# This wallet must have USDT0 deposited on Nado
NADO_PRIVATE_KEY=0x...

# ====================
# NETWORK
# ====================

# Network: mainnet or testnet
NADO_NETWORK=mainnet

# Subaccount name (max 12 bytes, default="default")
NADO_SUBACCOUNT_NAME=default

# ====================
# TRADING
# ====================

# Product IDs to trade (comma separated)
# 2=ETH-PERP, 3=SOL-PERP, 4=BTC-PERP, 5=BNB-PERP, 6=XRP-PERP
NADO_TRADING_PRODUCTS=2,4

# Trade size range in USD
NADO_MIN_TRADE_AMOUNT=10.0
NADO_MAX_TRADE_AMOUNT=50.0

# How long to hold position (seconds)
NADO_HOLD_TIME_MIN=5.0
NADO_HOLD_TIME_MAX=30.0

# Delay between trade cycles (seconds)
NADO_DELAY_BETWEEN_TRADES=2.0

# Use spot leverage (faster rate limits: 600 vs 30 orders/min)
NADO_USE_SPOT_LEVERAGE=true

# ====================
# TELEGRAM (optional)
# ====================

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=
TELEGRAM_ENABLE_NOTIFICATIONS=true

# ====================
# LOGGING
# ====================

LOG_LEVEL=INFO
